{
  "firestore": {
    "rules": "firestore.rules"
  },

  "storage": {
    "rules": "storage.rules"
  },

  "hosting": {
    "public": "build/web",

    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],

    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },

  "flutter": {
    "platforms": {
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "construction-managerr",

          "configurations": {
            "android": "1:113054719642:android:7f0ca5ed83a2d702470923",

            "web": "1:113054719642:web:4e45e8dfffdde45c470923"
          }
        }
      },

      "android": {
        "default": {
          "projectId": "construction-managerr",

          "appId": "1:113054719642:android:7f0ca5ed83a2d702470923",

          "fileOutput": "android/app/google-services.json"
        }
      }
    }
  }
}