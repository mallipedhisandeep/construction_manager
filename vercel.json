{
  "installCommand": "bash scripts/install_flutter.sh",
  "buildCommand": "export PATH=$PATH:/opt/flutter/bin && flutter build web --release --dart-define=SUPABASE_URL=$SUPABASE_URL --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY",
  "outputDirectory": "build/web",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
